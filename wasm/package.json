{
  "name": "@holmrenser/nj",
  "version": "0.0.15",
  "description": "Neighbor-Joining phylogenetic tree inference. Auto-detects DNA/protein, supports multiple substitution models and bootstrap.",
  "license": "MIT",
  "keywords": [
    "phylogenetics",
    "bioinformatics",
    "neighbor-joining",
    "newick",
    "wasm"
  ],
  "homepage": "https://github.com/holmrenser/nj.rs#readme",
  "bugs": "https://github.com/holmrenser/nj.rs/issues",
  "type": "module",
  "main": "./pkg-node/nj_js.js",
  "module": "./pkg-web/nj_js.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/holmrenser/nj.rs"
  },
  "types": "nj.d.ts",
  "scripts": {
    "build:web": "wasm-pack build --target bundler --out-dir pkg-web --release --no-typescript",
    "build:node": "wasm-pack build --target nodejs --out-dir pkg-node --release --no-typescript",
    "build": "npm run build:web && npm run build:node && rm */.gitignore",
    "clean": "rm -rf pkg-web pkg-node",
    "test:web": "NODE_OPTIONS=--experimental-wasm-modules mocha --recursive --extensions mjs --exit \"tests/*.web.test.js\"",
    "test:node": "node --test tests/nj_js.node.test.mjs",
    "test": "npm run test:web && npm run test:node"
  },
  "files": [
    "pkg-web",
    "pkg-node",
    "nj.d.ts",
    "types"
  ],
  "devDependencies": {
    "@esm-bundle/chai": "^4.3.4-fix.0",
    "mocha": "^11.7.5",
    "wasm-pack": "^0.13.0"
  }
}
